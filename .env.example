# Провайдеры (mock или gptunnel)
LLM_PROVIDER=gptunnel
IMAGE_PROVIDER=gptunnel

# GPTunnel Настройки
GPTTUNNEL_API_KEY=MY_KEY
GPTTUNNEL_BASE_URL=https://gptunnel.ru/v1

# Модели
LLM_MODEL=gpt-4o-mini
IMAGE_MODEL=grok-imagine
DEFAULT_COUNT=3
MAX_COUNT=10

# Продуктовые лимиты
TARGET_AGE_MIN=3
TARGET_AGE_MAX=5
STORY_SENTENCES_MIN=3
STORY_SENTENCES_MAX=5
MIN_QUESTIONS=2
MAX_QUESTIONS=3

# Пороги пайплайна
USER_ARBITRATION_THRESHOLD=3
MAX_VALIDATION_RETRIES=5
MIN_CHILD_INDEX=0.3
DEFAULT_IDEA_CHILD_INDEX=0.5
FALLBACK_IDEA_CHILD_INDEX=0.7
SCORE_NORMALIZATION_EPSILON=0.2

# Настройки провайдеров
HTTP_REQUEST_TIMEOUT_SECONDS=10
MEDIA_POLL_MAX_ATTEMPTS=30
MEDIA_POLL_INTERVAL_SECONDS=25
MEDIA_RETRY_INTERVAL_SECONDS=10
IMAGE_ASPECT_RATIO=1:1

# Логирование
LOG_LEVEL=INFO
LOG_TO_FILE=false
LOG_FILE_PATH=logs/dreamydraw.log
LOG_FORMAT_COLORED=true

# LangFuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=true
LANGFUSE_PROJECT_NAME=dreamydraw
LANGFUSE_ENV=local
LANGFUSE_SAMPLE_RATE=1.0
LANGFUSE_CAPTURE_PROMPTS=false
LANGFUSE_PROMPT_PREVIEW_CHARS=300

# Настройки путей
OUTPUT_DIR=output
PROMPTS_DIR=src/prompts
MOCKS_DIR=assets/mocks
